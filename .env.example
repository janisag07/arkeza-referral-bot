# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated Telegram user IDs)
# Find your user ID by messaging @userinfobot
ADMIN_IDS=123456789,987654321

# Bot Settings
BOT_USERNAME=YourBotUsername
GROUP_LINK=https://t.me/yourgroup

# Rate limit: max joins per referrer within time window
RATE_LIMIT_MAX_JOINS=10
RATE_LIMIT_WINDOW_HOURS=24

# Referral verification requirements
# User must send X messages AND be in group for Y hours before referral counts
MIN_MESSAGES_FOR_VERIFICATION=3
MIN_HOURS_FOR_VERIFICATION=24
