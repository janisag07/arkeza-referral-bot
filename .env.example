# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated Telegram user IDs)
# Find your user ID by messaging @userinfobot
ADMIN_IDS=123456789,987654321

# Rate limit: max joins per referrer within time window
RATE_LIMIT_MAX_JOINS=10
RATE_LIMIT_WINDOW_HOURS=24

# Minimum messages required for referral to count
MIN_MESSAGES_FOR_VERIFICATION=1
