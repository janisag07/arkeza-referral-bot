# =====================================================
# Arkeza Referral Bot — Environment Configuration
# =====================================================

# ---- Telegram Bot ----
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Bot username (without @)
BOT_USERNAME=Arkezabot

# Comma-separated Telegram user IDs of admins
# Find your user ID by messaging @userinfobot
ADMIN_IDS=123456789,987654321

# Public Telegram group/channel link (shown to users in /start welcome)
GROUP_LINK=https://t.me/arkezahub

# Channel/Group ID where public milestones and admin announcements are posted.
# Use the chat ID (e.g. -1001234567890 for channels). Leave empty to log only.
ANNOUNCEMENT_CHANNEL_ID=

# ---- Webhook (Telegram → Bot) ----
# Public HTTPS URL where Telegram will deliver bot updates.
# Must be HTTPS reachable from Telegram (use nginx + Let's Encrypt or similar TLS terminator).
# Example: https://bot.arkeza.io
WEBHOOK_BASE_URL=https://your-public-domain.example

# Path Telegram posts to (defaults to /webhook/telegram)
WEBHOOK_TELEGRAM_PATH=/webhook/telegram

# Random secret token. Telegram echoes this in X-Telegram-Bot-Api-Secret-Token header
# so we can verify requests really come from Telegram. Generate with: openssl rand -hex 32
WEBHOOK_SECRET_TOKEN=change_me_to_random_string

# Local port the Express server listens on (behind nginx/reverse proxy)
PORT=3000

# ---- Arkeza Backend API ----
# Base URL for Mit's Arkeza API
ARKEZA_API_BASE_URL=https://arkza-api.arkeza.io/api/telegram/v1

# Optional bearer token if Mit issues one for authentication.
# Leave empty if API is unauthenticated (V1 spec does not mandate auth).
ARKEZA_API_KEY=

# Request timeout in milliseconds
ARKEZA_API_TIMEOUT_MS=10000

# ---- Arkeza API encryption (RSA-OAEP-SHA256 + AES-256-CBC hybrid) ----
# Mit's API rejects plain JSON with HTTP 400 "Missing encryption data".
# Once Mit shares his public key, set these and restart. Until then the
# bot sends plain JSON (which fails on /link-user but keeps the bot
# running and /version usable).
ARKEZA_ENCRYPT=false
# Option A: inline PEM (escape newlines as \n in .env)
ARKEZA_PUBLIC_KEY=
# Option B: path to a PEM file
ARKEZA_PUBLIC_KEY_FILE=./keys/tg-public.pem
# 'hybrid' (AES body + RSA-wrapped key) or 'rsa' (pure RSA, small payloads only)
ARKEZA_ENCRYPTION_MODE=hybrid
# 'standard' → { data, key, iv }   |   'flat' → { encryptedData }
ARKEZA_ENVELOPE_FORMAT=standard

# ---- Arkeza → Bot Webhook (Milestones + Announcements) ----
# Path Mit's backend posts milestone/announcement events to (defaults to /webhook/arkeza)
ARKEZA_WEBHOOK_PATH=/webhook/arkeza

# Optional shared secret. If set, we verify the X-Arkeza-Signature header on incoming events.
# Leave empty to accept all events (NOT recommended in production).
ARKEZA_WEBHOOK_SECRET=

# ---- Referral System (legacy M1-3, still active) ----
# Max joins per referrer within RATE_LIMIT_WINDOW_HOURS before flagging suspicious
RATE_LIMIT_MAX_JOINS=10
RATE_LIMIT_WINDOW_HOURS=24

# Referral verification thresholds
MIN_MESSAGES_FOR_VERIFICATION=3
MIN_HOURS_FOR_VERIFICATION=24

# ---- In-group welcome + info-command URLs ----
# Auto-welcome new members in the group with a deep-link to start the bot.
# Set to 'false' to disable.
WELCOME_NEW_MEMBERS=true

# Auto-delete bot replies in groups/supergroups after N seconds to keep
# the chat clean (matches the community bot's long-standing behavior).
# DMs are never auto-deleted. Set AUTO_DELETE_BOT_MESSAGES=false to disable.
AUTO_DELETE_BOT_MESSAGES=true
AUTO_DELETE_SECONDS=60

# URLs surfaced by /website, /twitter, /whitepaper, /app, /contract commands
# and by the welcome/link-success inline keyboards.
WEBSITE_URL=https://arkeza.io/
TWITTER_URL=https://x.com/arkeza_hub
WHITEPAPER_URL=https://arkeza.io/assets/document/whitepaper.pdf
APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.arkeza.app
APP_IOS_URL=https://apps.apple.com/us/app/arkeza/id6757733204
CONTRACT_ADDRESS=Token Launch Upcoming — Stay tuned!
